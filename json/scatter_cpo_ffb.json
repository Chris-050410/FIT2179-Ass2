{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Interactive scatter plot showing the relationship between CPO price and FFB price across Malaysian regions.",
  "width": 790,
  "height": 250,
  "data": {
    "url": "data/combine_ffb_cpo.csv"
  },
  "transform": [
    {
      "filter": "datum.CPO_RM_Tonnes > 0 && datum.FFB_RM_Tonnes > 0"
    }
  ],
  "params": [
    {
      "name": "selectedRegion",
      "select": {
        "type": "point",
        "fields": ["Region"]
      },
      "bind": "legend"
    }
  ],
  "mark": {
    "type": "point",
    "filled": true,
    "size": 200,
    "stroke": "white",
    "strokeWidth": 0.5
  },
  "encoding": {
    "x": {
      "field": "CPO_RM_Tonnes",
      "type": "quantitative",
      "title": "Crude Palm Oil Price (RM/Tonnes)",
      "scale": {
        "zero": false,
        "domain": [800, 3400],
        "nice": false
      }
    },
    "y": {
      "field": "FFB_RM_Tonnes",
      "type": "quantitative",
      "title": "Fresh Fruit Bunch Price (RM/Tonnes)",
      "scale": {
        "zero": false,
        "domain": [5, 40],
        "nice": false
      }
    },
    "xOffset": {
      "field": "Region"
    },
    "yOffset": {
      "field": "Region"
    },
    "color": {
      "field": "Region",
      "type": "nominal",
      "title": "Region",
      "scale": {
        "domain": [
          "North",
          "South",
          "Central",
          "East Coast",
          "Sabah",
          "Sarawak"
        ],
        "range": [
          "#4E79A7",
          "#F28E2B",
          "#76B7B2",
          "#EDC948",
          "#B07AA1",
          "#FF9DA7"
        ]
      },
      "legend": {
        "orient": "none",
        "direction": "vertical",
        "legendY": 20,
        "legendX": 20,
        "labelFontSize": 14,
        "titleFontSize": 16,
        "symbolSize": 300,
        "symbolOpacity": 1,
        "columns": 3,
        "title": "Zone"
      }
    },
    "opacity": {
      "condition": {
        "param": "selectedRegion",
        "value": 1,
        "empty": false
      },
      "value": 0.5
    },
    "size": {
      "condition": {
        "param": "selectedRegion",
        "value": 350,
        "empty": false
      },
      "value": 180
    },
    "tooltip": [
      {
        "field": "Year",
        "type": "ordinal",
        "title": "Year"
      },
      {
        "field": "Region",
        "type": "nominal",
        "title": "Zone"
      },
      {
        "field": "CPO_RM_Tonnes",
        "type": "quantitative",
        "title": "Crude Palm Oil Price (RM Tonnes)",
        "format": ".1f"
      },
      {
        "field": "FFB_RM_Tonnes",
        "type": "quantitative",
        "title": "Fresh Fruit Bunch Price (RM Tonnes)",
        "format": ".2f"
      }
    ]
  },
  "config": {
    "axis": {
      "grid": true
    },
    "view": {
      "stroke": null
    }
  }
}