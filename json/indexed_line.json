{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 750,
  "height": 430,
  "data": {
    "url": "data/CPO-Production.csv"
  },

  "params": [
    {
      "name": "SelectedCountryCPOIndex",
      "value": "All",
      "bind": {
        "input": "select",
        "name": "Select country: ",
        "options": [
          "All",
          "Indonesia",
          "Malaysia",
          "Thailand",
          "Colombia",
          "Nigeria",
          "Papua New Guinea",
          "Honduras",
          "Ghana"
        ]
      }
    }
  ],

  "transform": [
    {
      "fold": [
        "Indonesia",
        "Malaysia",
        "Thailand",
        "Colombia",
        "Nigeria",
        "Papua New Guinea",
        "Honduras",
        "Ghana"
      ],
      "as": ["Country", "Production"]
    },
    {
      "calculate": "toNumber(datum.Production)",
      "as": "ProductionNum"
    },
    {
      "calculate": "datum.Country == 'Indonesia' ? 21958 : datum.Country == 'Malaysia' ? 16994 : datum.Country == 'Thailand' ? 1360 : datum.Country == 'Colombia' ? 753 : datum.Country == 'Nigeria' ? 780 : datum.Country == 'Papua New Guinea' ? 488 : datum.Country == 'Honduras' ? 275 : 200",
      "as": "Baseline2010"
    },
    {
      "calculate": "(datum.ProductionNum / datum.Baseline2010) * 100",
      "as": "Index"
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "rule",
        "strokeDash": [4, 4],
        "color": "#777"
      },
      "encoding": {
        "y": {
          "datum": 100
        }
      }
    },

    {
      "mark": {
        "type": "text",
        "text": "Baseline",
        "align": "left",
        "baseline": "middle",
        "dx": 65,
        "color": "#777",
        "fontSize": 12
      },
      "encoding": {
        "x": {
          "value": 690
        },
        "y": {
          "datum": 100
        }
      }
    },

    {
      "mark": {
        "type": "line",
        "strokeWidth": 1.5,
        "color": "#C9C9C9",
        "opacity": 0.45
      },
      "encoding": {
        "x": {
          "field": "Period",
          "type": "ordinal",
          "title": "Year",
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "Index",
          "type": "quantitative",
          "title": "Production Index (2010 = 100)",
          "axis": {
            "format": ".0f"
          }
        },
        "detail": {
          "field": "Country"
        }
      }
    },

    {
      "transform": [
        {
          "filter": "SelectedCountryCPOIndex == 'All' || datum.Country == SelectedCountryCPOIndex"
        }
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "point": {
          "filled": true,
          "size": 40
        }
      },
      "encoding": {
        "x": {
          "field": "Period",
          "type": "ordinal"
        },
        "y": {
          "field": "Index",
          "type": "quantitative"
        },
        "color": {
          "field": "Country",
          "type": "nominal",
          "title": "Country",
          "scale": {
            "domain": [
              "Indonesia",
              "Malaysia",
              "Thailand",
              "Colombia",
              "Nigeria",
              "Papua New Guinea",
              "Honduras",
              "Ghana"
            ],
            "range": [
              "#1F77B4",
              "#9467BD",
              "#FF7F0E",
              "#8C564B",
              "#E377C2",
              "#17BECF",
              "#A6761D",
              "#7F7F7F"
            ]
          }
        },
        "detail": {
          "field": "Country"
        }
      }
    },

    {
      "transform": [
        {
          "filter": "SelectedCountryCPOIndex == 'All' || datum.Country == SelectedCountryCPOIndex"
        }
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 16,
        "opacity": 0.001
      },
      "encoding": {
        "x": {
          "field": "Period",
          "type": "ordinal"
        },
        "y": {
          "field": "Index",
          "type": "quantitative"
        },
        "detail": {
          "field": "Country"
        },
        "tooltip": [
          {
            "field": "Country",
            "type": "nominal"
          },
          {
            "field": "Period",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "ProductionNum",
            "type": "quantitative",
            "title": "Crude Palm Oil Production",
            "format": ","
          },
          {
            "field": "Index",
            "type": "quantitative",
            "title": "Production Index",
            "format": ".1f"
          }
        ]
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },
    "axis": {
      "domain": false,
      "tickSize": 0,
      "grid": true
    },
    "legend": {
      "labelFontSize": 12,
      "titleFontSize": 15,
      "orient": "none",
      "legendX": 30,
      "legendY": 15,
      "symbolSize": 300
    }
  }
}
