{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "description": "Small multiple line charts showing Malaysia palm oil export value by product from 2000 to 2020.",
  "data": {
    "url": "data/vol_val_exp_product.csv"
  },

  "transform": [
    {"filter": "datum['Value (RM Million)'] != '-'"},
    {
      "calculate": "toNumber(datum['Value (RM Million)'])",
      "as": "ValueRM"
    },
    {
      "calculate": "datum['Sub product'] && datum['Sub product'] != '' ? datum['Sub product'] : datum['Poduct']",
      "as": "ProductName"
    }
  ],

  "facet": {
    "field": "ProductName",
    "type": "nominal",
    "title": null,
    "sort": {
      "op": "sum",
      "field": "ValueRM",
      "order": "descending"
    }
  },

  "columns": 3,

  "spec": {
    "width": 200,
    "height": 100,

    "mark": {
      "type": "line",
      "point": {
        "filled": true,
        "size": 45
      },
      "strokeWidth": 2.5
    },

    "encoding": {
      "x": {
        "field": "Year",
        "type": "ordinal",
        "title": "Year",
        "axis": {
          "labelAngle": 0,
          "labelOverlap": true
        }
      },

      "y": {
        "field": "ValueRM",
        "type": "quantitative",
        "title": "Export Value (RM Million)"
      },

      "color": {
        "field": "ProductName",
        "type": "nominal",
        "legend": null,
        "scale": {
          "domain": [
            "Processed Palm Oil",
            "Oleochemicals",
            "Crude Palm Oil",
            "Processed Palm Kernel Oil",
            "Finished Products",
            "Other Oil Palm Products",
            "Crude Palm Kernel Oil",
            "Biodiesel",
            "Palm Kernel Cake"
          ],
          "range": [
            "#2A9D8F",
            "#3D5A80",
            "#F4A261",
            "#E9C46A",
            "#8E6C8A",
            "darkgreen",
            "#7A7A7A",
            "#4D4D4D",
            "#B8B08D"
          ]
        }
      },

      "tooltip": [
        {"field": "ProductName", "type": "nominal", "title": "Product"},
        {"field": "Year", "type": "ordinal"},
        {
          "field": "ValueRM",
          "type": "quantitative",
          "title": "Value (RM Million)",
          "format": ","
        }
      ]
    }
  },

  "resolve": {
    "scale": {
      "y": "independent",
      "x": "shared"
    },
    "axis": {
      "x": "shared"
    }
  },

  "config": {
    "view": {
      "stroke": "#d9d9d9"
    },
    "axis": {
      "labelFontSize": 10,
      "titleFontSize": 11
    },
    "header": {
      "labelFontSize": 12,
      "labelFontWeight": "bold"
    }
  }
}
