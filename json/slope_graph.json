{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 700,
  "height": 420,

  "title": {
    "text": "Malaysia Palm Oil Export Rankings Changed Over Time",
    "subtitle": "Export value ranking by product every 5 years"
  },

  "data": {
    "url": "../data/vol_val_exp_product.csv"
  },

  "transform": [
    {
      "calculate": "datum['Sub product'] == null || datum['Sub product'] == '' ? datum['Poduct'] : datum['Sub product']",
      "as": "ProductName"
    },

    {
      "filter": "indexof(['2000','2005','2010','2015','2020'], toString(datum.Year)) >= 0"
    },

    {
      "filter": "datum['Value (RM Million)'] != '-' && datum['Value (RM Million)'] != null"
    },

    {
      "calculate": "toNumber(datum['Value (RM Million)'])",
      "as": "ExportValue"
    },

    {
      "window": [
        {
          "op": "rank",
          "as": "Rank"
        }
      ],

      "sort": [
        {
          "field": "ExportValue",
          "order": "descending"
        }
      ],

      "groupby": ["Year"]
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "line",
        "point": {
          "filled": true,
          "size": 80
        },
        "strokeWidth": 3
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": null,
          "sort": ["2000", "2005", "2010", "2015", "2020"],

          "axis": {
            "labelAngle": 0
          }
        },

        "y": {
          "field": "Rank",
          "type": "quantitative",
          "title": "Export Value Rank",

          "scale": {
            "reverse": true,
            "domain": [1, 9]
          },

          "axis": {
            "tickMinStep": 1
          }
        },

        "color": {
  "field": "ProductName",
  "type": "nominal",
  "title": "Product",
  "scale": {
    "domain": [
      "Processed Palm Oil",
      "Oleochemicals",
      "Crude Palm Oil",
      "Processed Palm Kernel Oil",
      "Finished Products",
      "Other Oil Palm Products",
      "Crude Palm Kernel Oil",
      "Biodiesel",
      "Palm Kernel Cake"
    ],
    "range": [
      "#2A9D8F",
      "#3D5A80",
      "#F4A261",
      "#E9C46A",
      "#8E6C8A",
      "darkgreen",
      "#7A7A7A",
      "#4D4D4D",
      "#B8B08D"
    ]
  }
},

        "detail": {
          "field": "ProductName"
        },

        "tooltip": [
          {
            "field": "ProductName",
            "type": "nominal",
            "title": "Product"
          },
          {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "Rank",
            "type": "quantitative",
            "title": "Rank"
          },
          {
            "field": "ExportValue",
            "type": "quantitative",
            "title": "Export Value (RM Million)",
            "format": ","
          }
        ]
      }
    },

    {
      "transform": [
        {
          "filter": "toString(datum.Year) == '2020'"
        }
      ],

      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 11
      },

      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "sort": ["2000", "2005", "2010", "2015", "2020"]
        },

        "y": {
          "field": "Rank",
          "type": "quantitative",

          "scale": {
            "reverse": true,
            "domain": [1, 9]
          }
        },

        "text": {
          "field": "ProductName"
        },

        "color": {
          "field": "ProductName",
          "type": "nominal",

          "scale": {
            "range": [
              "#1f77b4",
              "#ff7f0e",
              "#9467bd",
              "#17becf",
              "#8c564b",
              "#e377c2",
              "#7f7f7f",
              "#bcbd22",
              "#4c78a8"
            ]
          },

          "legend": null
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "grid": true,
      "labelFontSize": 11,
      "titleFontSize": 12
    },

    "title": {
      "anchor": "start",
      "fontSize": 15,
      "subtitleFontSize": 12
    },

    "legend": {
      "orient": "right",
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}