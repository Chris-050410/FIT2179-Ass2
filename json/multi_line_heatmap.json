{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "data/combine_ffb_cpo.csv"
  },
  "spacing": 22,
  "vconcat": [
    {
      "width": 900,
      "height": 300,
      "params": [
        {
          "name": "selectedCells",
          "select": {
            "type": "interval",
            "encodings": ["x", "y"]
          }
        }
      ],
      "mark": {
        "type": "rect",
        "stroke": "white",
        "strokeWidth": 0.6
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": "Year",
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "Region",
          "type": "nominal",
          "title": "Region",
          "sort": [
            "North",
            "South",
            "Central",
            "East Coast",
            "Sabah",
            "Sarawak"
          ],
          "axis": {
            "minExtent": 50,
            "maxExtent": 50,
            "titlePadding": 18,
            "titleFontSize": 12,
            "labelPadding": 4
          }
        },
        "color": {
          "field": "FFB_RM_Tonnes",
          "type": "quantitative",
          "title": "FFB Price",
          "scale": {
            "range": [
              "#fff7bc",
              "#fee391",
              "#fec44f",
              "#fe9929",
              "#d95f0e",
              "#993404"
            ]
          }
        },
        "opacity": {
          "condition": {
            "param": "selectedCells",
            "value": 1
          },
          "value": 0.35
        },
        "tooltip": [
          {
            "field": "Year",
            "type": "ordinal",
            "title": "Year"
          },
          {
            "field": "Region",
            "type": "nominal",
            "title": "Region"
          },
          {
            "field": "FFB_RM_Tonnes",
            "type": "quantitative",
            "title": "FFB Price(RM Tonnes)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "title": {
        "text": "Regional FFB Price Trends",
        "subtitle": "Selected heatmap range is highlighted while full trend remains visible",
        "anchor": "start",
        "offset": 8
      },
      "facet": {
        "field": "Region",
        "type": "nominal",
        "sort": [
          "North",
          "South",
          "Central",
          "East Coast",
          "Sabah",
          "Sarawak"
        ],
        "header": {
          "title": null,
          "labelFontSize": 12,
          "labelFontWeight": "bold",
          "labelPadding": 8
        }
      },
      "columns": 3,
      "bounds": "full",
      "spacing": {
        "row": 25,
        "column": 10
      },
      "spec": {
        "width": 220,
        "height": 150,
        "layer": [
          {
            "mark": {
              "type": "line",
              "strokeWidth": 2,
              "opacity": 0.38,
              "color": "#bdbdbd"
            },
            "encoding": {
              "x": {
                "field": "Year",
                "type": "ordinal",
                "title": "Year",
                "axis": {
                  "labelAngle": -45,
                  "labelFontSize": 8,
                  "titleFontSize": 9,
                  "labelOverlap": false
                }
              },
              "y": {
                "field": "FFB_RM_Tonnes",
                "type": "quantitative",
                "title": "FFB Price(RM Tonnes)",
                "scale": {
                  "domain": [6, 40],
                  "nice": false
                },
                "axis": {
                  "labelFontSize": 12,
                  "titleFontSize": 12,
                  "labelPadding": 10,
                  "titlePadding": 22,
                  "minExtent": 44,
                  "maxExtent": 50
                }
              }
            }
          },
          {
            "transform": [
              {
                "filter": {
                  "param": "selectedCells"
                }
              }
            ],
            "mark": {
              "type": "line",
              "strokeWidth": 4,
              "point": {
                "filled": true,
                "size": 35
              }
            },
            "encoding": {
              "x": {
                "field": "Year",
                "type": "ordinal",
                "title": "Year",
                "axis": {
                  "labelAngle": -45,
                  "labelFontSize": 8,
                  "titleFontSize": 9,
                  "labelOverlap": false
                }
              },
              "y": {
                "field": "FFB_RM_Tonnes",
                "type": "quantitative"
              },
              "color": {
                "field": "Region",
                "type": "nominal",
                "legend": null,
                "scale": {
                  "domain": [
                    "North",
                    "South",
                    "Central",
                    "East Coast",
                    "Sabah",
                    "Sarawak"
                  ],
                  "range": [
                    "#4E79A7",
                    "#F28E2B",
                    "#76B7B2",
                    "#EDC948",
                    "#B07AA1",
                    "#FF9DA7"
                  ]
                }
              },
              "tooltip": [
                {
                  "field": "Year",
                  "type": "ordinal",
                  "title": "Year"
                },
                {
                  "field": "Region",
                  "type": "nominal",
                  "title": "Region"
                },
                {
                  "field": "FFB_RM_Tonnes",
                  "type": "quantitative",
                  "title": "FFB Price(RM Tonnes)",
                  "format": ".2f"
                }
              ]
            }
          }
        ]
      },
      "resolve": {
        "scale": {
          "x": "shared",
          "y": "shared",
          "color": "shared"
        },
        "axis": {
          "x": "shared"
        }
      }
    }
  ],
  "config": {
    "axis": {
      "grid": true
    },
    "view": {
      "stroke": null
    }
  }
}
