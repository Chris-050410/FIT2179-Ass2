{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {
    "url": "data/combine_ffb_cpo.csv"
  },
  "hconcat": [
    {
      "width": 760,
      "height": 400,
      "params": [
        {
          "name": "selectedCells",
          "select": {
            "type": "interval",
            "encodings": ["x", "y"]
          }
        }
      ],
      "mark": {
        "type": "rect",
        "stroke": "white",
        "strokeWidth": 0.6
      },
      "encoding": {
        "x": {
          "field": "Year",
          "type": "ordinal",
          "title": "Year",
          "axis": {
            "labelAngle": 0
          }
        },
        "y": {
          "field": "Region",
          "type": "nominal",
          "title": null,
          "sort": ["North", "South", "Central", "East Coast", "Sabah", "Sarawak"],
          "axis": {
            "labelFontSize": 12,
            "titleFontSize": 10
          }
        },
        "color": {
          "field": "FFB_RM_Tonnes",
          "type": "quantitative",
          "title": "Fresh Fruit Bunch Price",
          "legend": {
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 250,
            "titleFontSize": 11,
            "labelFontSize": 10,
            "offset": -4
          },
          "scale": {
            "range": ["#fff7bc", "#fee391", "#fec44f", "#fe9929", "#d95f0e", "#993404"]
          }
        },
        "opacity": {
          "condition": {
            "param": "selectedCells",
            "value": 1
          },
          "value": 0.35
        },
        "tooltip": [
          {"field": "Year", "type": "ordinal", "title": "Year"},
          {"field": "Region", "type": "nominal", "title": "Region"},
          {
            "field": "FFB_RM_Tonnes",
            "type": "quantitative",
            "title": "Fresh Fruit Bunch Price(RM Tonnes)",
            "format": ".2f"
          }
        ]
      }
    },
    {
      "title": {
        "text": "Fresh Fruit Bunch (RM Tonnes)",
        "orient": "left",
        "anchor": "middle",
        "angle": 270,
        "fontSize": 10
      },
      "facet": {
        "field": "Region",
        "type": "nominal",
        "title": null,
        "sort": ["North", "South", "Central", "East Coast", "Sabah", "Sarawak"]
      },
      "columns": 2,
      "spacing": 5,
      "spec": {
        "width": 150,
        "height": 50,
        "layer": [
          {
            "mark": {
              "type": "line",
              "strokeWidth": 2,
              "opacity": 0.38,
              "color": "#bdbdbd"
            },
            "encoding": {
              "x": {
                "field": "Year",
                "type": "ordinal",
                "title": "Year",
                "axis": {
                  "values": [2000, 2002, 2004, 2006, 2008, 2010, 2012, 2014, 2016],
                  "labelAngle": -45,
                  "labelFontSize": 8,
                  "titleFontSize": 9
                }
              },
              "y": {
                "field": "FFB_RM_Tonnes",
                "type": "quantitative",
                "title": null,
                "scale": {
                  "domain": [6, 40],
                  "nice": false
                },
                "axis": {
                  "labelFontSize": 10,
                  "title": null
                }
              },
              "tooltip": [
                {"field": "Year", "type": "ordinal", "title": "Year"},
                {"field": "Region", "type": "nominal", "title": "Region"},
                {
                  "field": "FFB_RM_Tonnes",
                  "type": "quantitative",
                  "title": "Fresh Fruit Bunch Price(RM Tonnes)",
                  "format": ".2f"
                }
              ]
            }
          },
          {
            "transform": [
              {
                "filter": {
                  "param": "selectedCells"
                }
              }
            ],
            "mark": {
              "type": "line",
              "strokeWidth": 4,
              "point": {
                "filled": true,
                "size": 35
              }
            },
            "encoding": {
              "x": {
                "field": "Year",
                "type": "ordinal"
              },
              "y": {
                "field": "FFB_RM_Tonnes",
                "type": "quantitative"
              },
              "color": {
                "field": "Region",
                "type": "nominal",
                "legend": null,
                "scale": {
                  "domain": ["North", "South", "Central", "East Coast", "Sabah", "Sarawak"],
                  "range": ["#4E79A7", "#F28E2B", "#76B7B2", "#EDC948", "#B07AA1", "#FF9DA7"]
                }
              },
              "tooltip": [
                {"field": "Year", "type": "ordinal", "title": "Year"},
                {"field": "Region", "type": "nominal", "title": "Region"},
                {
                  "field": "FFB_RM_Tonnes",
                  "type": "quantitative",
                  "title": "Fresh Fruit Bunch Price(RM Tonnes)",
                  "format": ".2f"
                }
              ]
            }
          }
        ]
      },
      "resolve": {
        "scale": {
          "x": "shared",
          "y": "shared"
        },
        "axis": {
          "x": "shared",
          "y": "shared"
        }
      }
    }
  ],
  "spacing": 50,
  "config": {
    "axis": {
      "grid": true
    },
    "view": {
      "stroke": null
    },
    "header": {
      "labelFontSize": 12,
      "labelFontWeight": "bold",
      "labelPadding": 0
    }
  }
}