{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 760,
  "height": 420,
  "title": {
    "text": "Malaysia is a Key Player in the Global Palm Oil Industry",
    "subtitle": "CPO production across major producing countries, 2010–2024"
  },
  "data": {
    "url": "../data/CPO-Production.csv"
  },
  "transform": [
    {
      "fold": [
        "Indonesia",
        "Malaysia",
        "Thailand",
        "Colombia",
        "Nigeria",
        "Papua New Guinea",
        "Honduras",
        "Ghana"
      ],
      "as": ["Country", "CPO_Production"]
    }
  ],
  "encoding": {
    "x": {
      "field": "Period",
      "type": "ordinal",
      "title": "Year",
      "axis": {"labelAngle": 0}
    },
    "y": {
      "field": "CPO_Production",
      "type": "quantitative",
      "title": "CPO Production (Thousand Tonnes)"
    },
    "detail": {
      "field": "Country",
      "type": "nominal"
    }
  },
  "layer": [
    {
      "params": [
        {
          "name": "hoverCountry",
          "select": {
            "type": "point",
            "fields": ["Country"],
            "on": "mouseover",
            "clear": "mouseout"
          }
        }
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 28,
        "strokeCap": "round",
        "strokeJoin": "round",
        "opacity": 0.01
      },
      "encoding": {
        "tooltip": [
          {"field": "Country", "type": "nominal"},
          {"field": "Period", "type": "ordinal", "title": "Year"},
          {
            "field": "CPO_Production",
            "type": "quantitative",
            "title": "CPO Production (Thousand Tonnes)",
            "format": ","
          }
        ]
      }
    },
    {
      "mark": {
        "type": "line",
        "point": false,
        "strokeCap": "round",
        "strokeJoin": "round"
      },
      "encoding": {
        "color": {
          "condition": [
            {
              "test": "datum.Country == 'Malaysia'",
              "value": "#d95f02"
            },
            {
              "test": "datum.Country == 'Indonesia'",
              "value": "#4d4d4d"
            },
            {
              "test": "datum.Country == 'Thailand'",
              "value": "#7a7a7a"
            }
          ],
          "value": "#a8a8a8"
        },
        "strokeWidth": {
          "condition": [
            {
              "test": "datum.Country == 'Malaysia'",
              "value": 4
            },
            {
              "test": "datum.Country == 'Indonesia'",
              "value": 3
            },
            {
              "test": "datum.Country == 'Thailand'",
              "value": 2.4
            }
          ],
          "value": 1.8
        },
        "opacity": {
          "condition": {
            "param": "hoverCountry",
            "value": 1
          },
          "value": 0.75
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Country == 'Malaysia'"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "size": 60,
        "color": "#d95f02"
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Period == 2024 && (datum.Country == 'Indonesia' || datum.Country == 'Malaysia' || datum.Country == 'Thailand')"
        }
      ],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 8,
        "fontSize": 12,
        "fontWeight": "bold"
      },
      "encoding": {
        "text": {"field": "Country"},
        "color": {
          "condition": [
            {
              "test": "datum.Country == 'Malaysia'",
              "value": "#d95f02"
            },
            {
              "test": "datum.Country == 'Indonesia'",
              "value": "#4d4d4d"
            }
          ],
          "value": "#7a7a7a"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.Period == 2024 && datum.Country == 'Nigeria'"
        }
      ],
      "mark": {
        "type": "text",
        "text": "Others",
        "align": "left",
        "dx": 8,
        "dy": 8,
        "fontSize": 11,
        "fontStyle": "italic",
        "color": "#777777"
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "size": 180,
        "opacity": 0
      },
      "encoding": {
        "tooltip": [
          {"field": "Country", "type": "nominal"},
          {"field": "Period", "type": "ordinal", "title": "Year"},
          {
            "field": "CPO_Production",
            "type": "quantitative",
            "title": "CPO Production (Thousand Tonnes)",
            "format": ","
          }
        ]
      }
    }
  ],
  "config": {
    "view": {"stroke": null},
    "axis": {
      "grid": true,
      "labelFontSize": 12,
      "titleFontSize": 13
    }
  }
}