{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Malaysia choropleth map with neighbouring countries, graticule, linked bar chart and hover multi-line chart.",
  "params": [
    {
      "name": "selectedYear",
      "value": 2016,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2016,
        "step": 1,
        "name": "Year: "
      }
    }
  ],
  "hconcat": [
    {
      "width": 850,
      "height": 500,
      "projection": {
        "type": "mercator",
        "center": [99.4, 10.0],
        "scale": 2500
      },
      "layer": [
        {
          "data": {"sphere": true},
          "mark": {"type": "geoshape", "fill": "#dfeff7"}
        },
        {
          "data": {
            "url": "json/malaysia_map.json",
            "format": {
              "type": "topojson",
              "feature": "ne_10m_graticules_1"
            }
          },
          "mark": {
            "type": "geoshape",
            "stroke": "#b8c7cf",
            "strokeWidth": 0.5,
            "fill": null
          }
        },
        {
          "data": {
            "url": "json/malaysia_map.json",
            "format": {
              "type": "topojson",
              "feature": "ne_10m_admin_0_countries"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#e9e9e9",
            "stroke": "#8f8f8f",
            "strokeWidth": 0.5
          }
        },
        {
          "data": {
            "url": "json/malaysia_map.json",
            "format": {
              "type": "topojson",
              "feature": "malaysia.state"
            }
          },
          "transform": [
            {"calculate": "datum.properties.name", "as": "StateClean"},
            {
              "calculate": "datum.properties.name + '-' + selectedYear",
              "as": "StateYear"
            },
            {
              "lookup": "StateYear",
              "from": {
                "data": {
                  "url": "data/num_independent_smallholder_state.csv"
                },
                "key": "StateYear",
                "fields": ["Value", "Year"]
              }
            }
          ],
          "params": [
            {
              "name": "selectState",
              "select": {
                "type": "point",
                "fields": ["StateClean"],
                "on": "click",
                "clear": "dblclick"
              }
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "white",
            "strokeWidth": 1
          },
          "encoding": {
            "color": {
              "field": "Value",
              "type": "quantitative",
              "title": "Smallholders",
              "scale": {"scheme": "oranges"},
              "legend": {
                "orient": "bottom",
                "offset": 6,
                "gradientLength": 350,
                "labelFontSize": 12,
                "titleFontSize": 15
              }
            },
            "opacity": {
              "condition": {"param": "selectState", "value": 1},
              "value": 0.9
            },
            "tooltip": [
              {"field": "StateClean", "type": "nominal", "title": "State"},
              {"field": "Year", "type": "quantitative", "title": "Year"},
              {
                "field": "Value",
                "type": "quantitative",
                "title": "Smallholders",
                "format": ","
              }
            ]
          }
        },
        {
          "data": {
            "values": [
              {"State": "Perlis", "lon": 100.2, "lat": 6.55},
              {"State": "Kedah", "lon": 100.65, "lat": 6.05},
              {"State": "Pulau Pinang", "lon": 100.30, "lat": 5.38},
              {"State": "Perak", "lon": 101.0, "lat": 4.65},
              {"State": "Kelantan", "lon": 102.0, "lat": 5.15},
              {"State": "Terengganu", "lon": 103.05, "lat": 4.85},
              {"State": "Pahang", "lon": 102.65, "lat": 3.75},
              {"State": "Selangor", "lon": 101.5, "lat": 3.35},
              {"State": "Negeri Sembilan", "lon": 102.2, "lat": 2.75},
              {"State": "Melaka", "lon": 102.3, "lat": 2.3},
              {"State": "Johor", "lon": 103.45, "lat": 2.1},
              {"State": "Sabah", "lon": 117.0, "lat": 5.45},
              {"State": "Sarawak", "lon": 113.0, "lat": 2.5}
            ]
          },
          "mark": {
            "type": "text",
            "fontSize": 12,
            "fontWeight": "bold",
            "fill": "white",
            "stroke": "black",
            "strokeWidth": 0.5,
            "align": "center",
            "baseline": "middle"
          },
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude": {"field": "lat", "type": "quantitative"},
            "text": {"field": "State", "type": "nominal"}
          }
        }
      ]
    },
    {
      "vconcat": [
        {
          "width": 280,
          "height": 200,
          "data": {
            "url": "data/num_independent_smallholder_state.csv"
          },
          "transform": [
            {"filter": "datum.Year == selectedYear"},
            {"calculate": "datum.State", "as": "StateClean"}
          ],
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 4
          },
          "encoding": {
            "y": {
              "field": "State",
              "type": "nominal",
              "sort": "-x",
              "title": null
            },
            "x": {
              "field": "Value",
              "type": "quantitative",
              "title": "Number of Independent Smallholders",
              "axis": {
                "labelFontSize": 10,
                "titleFontSize": 12,
                "labelFlush": false,
                "values": [0, 20000, 40000, 60000, 80000]
              }
            },
            "color": {
              "condition": {"param": "selectState", "value": "#C75B12"},
              "value": "#c7c7c7"
            },
            "opacity": {
              "condition": {"param": "selectState", "value": 1},
              "value": 0.65
            },
            "tooltip": [
              {"field": "State", "type": "nominal", "title": "State"},
              {"field": "Year", "type": "quantitative", "title": "Year"},
              {
                "field": "Value",
                "type": "quantitative",
                "title": "Smallholders",
                "format": ","
              }
            ]
          }
        },
        {
  "width": 280,
  "height": 50,

  "data": {
    "values": [
      {
        "text": "East Malaysia’s dominance reflects its\n extensive land availability and long-established\n palm cultivation industry."
      }
    ]
  },

  "mark": {
    "type": "text",
    "align": "left",
    "baseline": "top",
    "font": "Arial",
    "fontSize": 15,
    "lineBreak": "\n",
    "dx": -155,
    "color": "black"
  },

  "encoding": {
    "text": {
      "field": "text"
    }
  }
}]
}]}