{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Malaysia choropleth map using state share of national smallholders.",
  "params": [
    {
      "name": "selectedYear",
      "value": 2016,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2016,
        "step": 1,
        "name": "Year: "
      }
    }
  ],
  "hconcat": [
    {
      "width": 850,
      "height": 430,
      "projection": {
        "type": "mercator",
        "center": [99.4, 10.0],
        "scale": 2500
      },
      "layer": [
        {
          "data": {"sphere": true},
          "mark": {"type": "geoshape", "fill": "#dfeff7"}
        },
        {
          "data": {
            "url": "json/malaysia_map.json",
            "format": {
              "type": "topojson",
              "feature": "ne_10m_graticules_1"
            }
          },
          "mark": {
            "type": "geoshape",
            "stroke": "#b8c7cf",
            "strokeWidth": 0.5,
            "fill": null
          }
        },
        {
          "data": {
            "url": "json/malaysia_map.json",
            "format": {
              "type": "topojson",
              "feature": "ne_10m_admin_0_countries"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#e9e9e9",
            "stroke": "#8f8f8f",
            "strokeWidth": 0.5
          }
        },
        {
          "data": {
            "url": "json/malaysia_map.json",
            "format": {
              "type": "topojson",
              "feature": "malaysia.state"
            }
          },
          "transform": [
            {"calculate": "datum.properties.name", "as": "StateClean"},
            {
              "calculate": "datum.properties.name + '-' + selectedYear",
              "as": "StateYear"
            },
            {
              "lookup": "StateYear",
              "from": {
                "data": {
                  "url": "data/num_independent_smallholder_state.csv"
                },
                "key": "StateYear",
                "fields": ["Value", "Year"]
              }
            },
            {
              "joinaggregate": [
                {
                  "op": "sum",
                  "field": "Value",
                  "as": "TotalSmallholders"
                }
              ]
            },
            {
              "calculate": "datum.Value / datum.TotalSmallholders * 100",
              "as": "StateShare"
            },
            {
              "calculate": "datum.StateShare < 2 ? '0% - 2%' : datum.StateShare < 5 ? '2% - 5%' : datum.StateShare < 10 ? '5% - 10%' : datum.StateShare < 20 ? '10% - 20%' : '20%+'",
              "as": "ShareClass"
            }
          ],
          "params": [
            {
              "name": "selectState",
              "select": {
                "type": "point",
                "fields": ["StateClean"],
                "on": "click",
                "clear": "dblclick"
              }
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "white",
            "strokeWidth": 1
          },
          "encoding": {
            "color": {
              "field": "ShareClass",
              "type": "ordinal",
              "title": "Percentage Total Share",
              "scale": {
                "domain": ["0% - 2%", "2% - 5%", "5% - 10%", "10% - 20%", "20%+"],
                "range": ["#fff5eb", "#fdd0a2", "#fdae6b", "#f16913", "#8c2d04"]
              },
              "legend": {
                "orient": "bottom",
                "offset": -20,
                "labelFontSize": 12,
                "titleFontSize": 15,
                "symbolType": "square"
              }
            },
            "opacity": {
              "condition": {"param": "selectState", "value": 1},
              "value": 0.9
            },
            "tooltip": [
              {"field": "StateClean", "type": "nominal", "title": "State"},
              {"field": "Year", "type": "quantitative", "title": "Year"},
              {
                "field": "Value",
                "type": "quantitative",
                "title": "Smallholders",
                "format": ","
              },
              {
                "field": "TotalSmallholders",
                "type": "quantitative",
                "title": "Malaysia Total",
                "format": ","
              },
              {
                "field": "StateShare",
                "type": "quantitative",
                "title": "Share of Total",
                "format": ".2f"
              }
            ]
          }
        },
        {
          "data": {
            "values": [
              {"State": "Perlis", "lon": 100.2, "lat": 6.55},
              {"State": "Kedah", "lon": 100.65, "lat": 6.05},
              {"State": "Pulau Pinang", "lon": 100.30, "lat": 5.38},
              {"State": "Perak", "lon": 101.0, "lat": 4.65},
              {"State": "Kelantan", "lon": 102.0, "lat": 5.15},
              {"State": "Terengganu", "lon": 103.05, "lat": 4.85},
              {"State": "Pahang", "lon": 102.65, "lat": 3.75},
              {"State": "Selangor", "lon": 101.5, "lat": 3.35},
              {"State": "Negeri Sembilan", "lon": 102.2, "lat": 2.75},
              {"State": "Melaka", "lon": 102.3, "lat": 2.3},
              {"State": "Johor", "lon": 103.45, "lat": 2.1},
              {"State": "Sabah", "lon": 117.0, "lat": 5.45},
              {"State": "Sarawak", "lon": 113.0, "lat": 2.5}
            ]
          },
          "mark": {
            "type": "text",
            "fontSize": 12,
            "fontWeight": "bold",
            "fill": "#fdfdfd",
            "stroke": "#3f3f3f",
            "strokeWidth": 0.7,
            "align": "center",
            "baseline": "middle"
          },
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude": {"field": "lat", "type": "quantitative"},
            "text": {"field": "State", "type": "nominal"}
          }
        }
      ]
    },
    {
      "vconcat": [
        {
          "width": 300,
          "height": 300,
          "data": {
            "url": "data/num_independent_smallholder_state.csv"
          },
          "transform": [
            {"filter": "datum.Year == selectedYear"},
            {"calculate": "datum.State", "as": "StateClean"}
          ],
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 4
          },
          "encoding": {
            "y": {
              "field": "State",
              "type": "nominal",
              "sort": "-x",
              "title": null
            },
            "x": {
              "field": "Value",
              "type": "quantitative",
              "title": "Number of Independent Smallholders",
              "axis": {
                "labelFontSize": 10,
                "titleFontSize": 12,
                "labelFlush": false,
                "values": [0, 20000, 40000, 60000, 80000]
              }
            },
            "color": {
              "condition": {"param": "selectState", "value": "#C75B12"},
              "value": "#c7c7c7"
            },
            "opacity": {
              "condition": {"param": "selectState", "value": 1},
              "value": 0.65
            },
            "tooltip": [
              {"field": "State", "type": "nominal", "title": "State"},
              {"field": "Year", "type": "quantitative", "title": "Year"},
              {
                "field": "Value",
                "type": "quantitative",
                "title": "Smallholders",
                "format": ","
              }
            ]
          }
        },
        {
          "width": 280,
          "height": 50,
          "view": {
            "stroke": null
          },
          "data": {
            "values": [
              {
                "text": "Malaysia’s independent smallholder activity remains\n concentrated in a few dominant states, but over time\n the industry’s centre of influence increasingly shifts\n toward East Malaysia as Sabah and Sarawak expand\n their contribution to the national total."
              }
            ]
          },
          "mark": {
            "type": "text",
            "align": "left",
            "baseline": "top",
            "font": "Arial",
            "fontSize": 15,
            "lineBreak": "\n",
            "dx": -200,
            "color": "black"
          },
          "encoding": {
            "text": {
              "field": "text"
            }
          }
        }
      ]
    }
  ], "spacing": 20
}