{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Malaysia choropleth map with neighbouring countries, graticule, linked bar chart and hover multi-line chart.",
  "params": [
    {
      "name": "selectedYear",
      "value": 2016,
      "bind": {
        "input": "range",
        "min": 2000,
        "max": 2016,
        "step": 1,
        "name": "Year: "
      }
    }
  ],
  "hconcat": [
    {
      "width": 850,
      "height": 500,
      "projection": {
        "type": "mercator",
        "center": [99.4, 10.0],
        "scale": 2500
      },
      "layer": [
        {
          "data": {"sphere": true},
          "mark": {"type": "geoshape", "fill": "#dfeff7"}
        },
        {
          "data": {
            "url": "json/malaysia_map.json",
            "format": {
              "type": "topojson",
              "feature": "ne_10m_graticules_1"
            }
          },
          "mark": {
            "type": "geoshape",
            "stroke": "#b8c7cf",
            "strokeWidth": 0.5,
            "fill": null
          }
        },
        {
          "data": {
            "url": "json/malaysia_map.json",
            "format": {
              "type": "topojson",
              "feature": "ne_10m_admin_0_countries"
            }
          },
          "mark": {
            "type": "geoshape",
            "fill": "#e9e9e9",
            "stroke": "#8f8f8f",
            "strokeWidth": 0.5
          }
        },
        {
          "data": {
            "url": "json/malaysia_map.json",
            "format": {
              "type": "topojson",
              "feature": "malaysia.state"
            }
          },
          "transform": [
            {"calculate": "datum.properties.name", "as": "StateClean"},
            {
              "calculate": "datum.properties.name + '-' + selectedYear",
              "as": "StateYear"
            },
            {
              "lookup": "StateYear",
              "from": {
                "data": {
                  "url": "data/num_independent_smallholder_state.csv"
                },
                "key": "StateYear",
                "fields": ["Value", "Year"]
              }
            },
            {
  "calculate": "datum.StateClean == 'Johor' ? 19166 : datum.StateClean == 'Kedah' ? 9500 : datum.StateClean == 'Kelantan' ? 15099 : datum.StateClean == 'Melaka' ? 1664 : datum.StateClean == 'Negeri Sembilan' ? 6686 : datum.StateClean == 'Pahang' ? 35965 : datum.StateClean == 'Perak' ? 21035 : datum.StateClean == 'Perlis' ? 821 : datum.StateClean == 'Pulau Pinang' ? 1049 : datum.StateClean == 'Selangor' ? 8104 : datum.StateClean == 'Terengganu' ? 13035 : datum.StateClean == 'Sabah' ? 73631 : datum.StateClean == 'Sarawak' ? 124450 : null",
  "as": "StateArea"
},
{
  "calculate": "datum.Value / datum.StateArea",
  "as": "SmallholdersPerKm2"
}
          ],
          "params": [
            {
              "name": "selectState",
              "select": {
                "type": "point",
                "fields": ["StateClean"],
                "on": "click",
                "clear": "dblclick"
              }
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "white",
            "strokeWidth": 1
          },
          "encoding": {
            "color": {
              "field": "SmallholdersPerKm2",
              "type": "quantitative",
              "title": "Smallholders per km²",
              "bin": {
    "extent": [0, 10],
    "step": 2
  },
              "scale": {
    "scheme": "oranges"
  },
              "legend": {
                "orient": "bottom",
                "title": "Smallholders per km²",
                "labelFontSize": 12,
                "titleFontSize": 15
              }
            },
            "opacity": {
              "condition": {"param": "selectState", "value": 1},
              "value": 0.9
            },
            "tooltip": [
              {"field": "StateClean", "type": "nominal", "title": "State"},
              {"field": "Year", "type": "quantitative", "title": "Year"},
              {
                "field": "SmallholdersPerKm2",
                "type": "quantitative",
                "title": "Smallholders per km²",
                "format": ".2f"
              }
            ]
          }
        },
        {
          "data": {
            "values": [
              {"State": "Perlis", "lon": 100.2, "lat": 6.55},
              {"State": "Kedah", "lon": 100.65, "lat": 6.05},
              {"State": "Pulau Pinang", "lon": 100.30, "lat": 5.38},
              {"State": "Perak", "lon": 101.0, "lat": 4.65},
              {"State": "Kelantan", "lon": 102.0, "lat": 5.15},
              {"State": "Terengganu", "lon": 103.05, "lat": 4.85},
              {"State": "Pahang", "lon": 102.65, "lat": 3.75},
              {"State": "Selangor", "lon": 101.5, "lat": 3.35},
              {"State": "Negeri Sembilan", "lon": 102.2, "lat": 2.75},
              {"State": "Melaka", "lon": 102.3, "lat": 2.3},
              {"State": "Johor", "lon": 103.45, "lat": 2.1},
              {"State": "Sabah", "lon": 117.0, "lat": 5.45},
              {"State": "Sarawak", "lon": 113.0, "lat": 2.5}
            ]
          },
          "mark": {
            "type": "text",
            "fontSize": 12,
            "fontWeight": "bold",
            "fill": "white",
            "stroke": "black",
            "strokeWidth": 0.5,
            "align": "center",
            "baseline": "middle"
          },
          "encoding": {
            "longitude": {"field": "lon", "type": "quantitative"},
            "latitude": {"field": "lat", "type": "quantitative"},
            "text": {"field": "State", "type": "nominal"}
          }
        }
      ]
    },
    {
      "vconcat": [
        {
          "width": 280,
          "height": 200,
          "data": {
            "url": "data/num_independent_smallholder_state.csv"
          },
          "transform": [
            {"filter": "datum.Year == selectedYear"},
            {"calculate": "datum.State", "as": "StateClean"}
          ],
          "mark": {
            "type": "bar",
            "cornerRadiusEnd": 4
          },
          "encoding": {
            "y": {
              "field": "State",
              "type": "nominal",
              "sort": "-x",
              "title": null
            },
            "x": {
              "field": "Value",
              "type": "quantitative",
              "title": "Number of Independent Smallholders",
              "axis": {
                "labelFontSize": 10,
                "titleFontSize": 12,
                "labelFlush": false,
                "values": [0, 20000, 40000, 60000, 80000]
              }
            },
            "color": {
              "condition": {"param": "selectState", "value": "#C75B12"},
              "value": "#c7c7c7"
            },
            "opacity": {
              "condition": {"param": "selectState", "value": 1},
              "value": 0.65
            },
            "tooltip": [
              {"field": "State", "type": "nominal", "title": "State"},
              {"field": "Year", "type": "quantitative", "title": "Year"},
              {
                "field": "Value",
                "type": "quantitative",
                "title": "Smallholders",
                "format": ","
              }
            ]
          }
        },
        {
  "width": 280,
  "height": 50,

  "data": {
    "values": [
      {
        "text": "East Malaysia’s dominance reflects its\n extensive land availability and long-established\n palm cultivation industry."
      }
    ]
  },

  "mark": {
    "type": "text",
    "align": "left",
    "baseline": "top",
    "font": "Arial",
    "fontSize": 15,
    "lineBreak": "\n",
    "dx": -155,
    "color": "black"
  },

  "encoding": {
    "text": {
      "field": "text"
    }
  }
},
        {
          "width": 280,
          "height": 150,
          "data": {
            "url": "data/num_independent_smallholder_state.csv"
          },
          "transform": [
            {
              "joinaggregate": [
                {
                  "op": "sum",
                  "field": "Value",
                  "as": "TotalSmallholders"
                }
              ],
              "groupby": ["State"]
            },
            {
              "window": [
                {
                  "op": "dense_rank",
                  "as": "StateRank"
                }
              ],
              "sort": [
                {
                  "field": "TotalSmallholders",
                  "order": "descending"
                }
              ]
            },
            {
              "calculate": "datum.StateRank <= 6 ? datum.State : 'Others'",
              "as": "StateGroup"
            },
            {
              "joinaggregate": [
                {
                  "op": "max",
                  "field": "Year",
                  "as": "LatestYear"
                }
              ]
            },
            {
              "calculate": "datum.Year == datum.LatestYear",
              "as": "isLatest"
            }
          ],
          "encoding": {
            "x": {
              "field": "Year",
              "type": "ordinal",
              "title": "Year",
              "axis": {
                "values": [2000, 2002, 2004, 2006, 2008, 2010, 2012, 2014, 2016],
                "labelAngle": 0,
                "labelFontSize": 10,
                "titleFontSize": 10
              }
            },
            "y": {
              "field": "Value",
              "type": "quantitative",
              "title": "Number of Independent Smallholders",
              "axis": {
                "labelFontSize": 10,
                "titleFontSize": 10
              }
            },
            "detail": {
              "field": "State",
              "type": "nominal"
            }
          },
          "layer": [
            {
              "params": [
                {
                  "name": "hover",
                  "select": {
                    "type": "point",
                    "fields": ["State"],
                    "on": "mouseover",
                    "clear": "mouseout"
                  }
                }
              ],
              "mark": {
                "type": "line",
                "strokeWidth": 28,
                "strokeCap": "round",
                "strokeJoin": "round",
                "opacity": 0.01
              },
              "encoding": {
                "tooltip": [
                  {"field": "State", "type": "nominal", "title": "State"},
                  {"field": "Year", "type": "ordinal", "title": "Year"},
                  {
                    "field": "Value",
                    "type": "quantitative",
                    "title": "Smallholders",
                    "format": ","
                  }
                ]
              }
            },
            {
              "mark": {
                "type": "line",
                "strokeWidth": 3,
                "strokeCap": "round",
                "strokeJoin": "round"
              },
              "encoding": {
                "color": {
                  "field": "StateGroup",
                  "type": "nominal",
                  "scale": {
                    "domain": [
                      "Johor",
                      "Perak",
                      "Pahang",
                      "Sabah",
                      "Sarawak",
                      "Selangor",
                      "Others"
                    ],
                    "range": [
                      "#4E79A7",
                      "#F28E2B",
                      "#B07AA1",
                      "#76B7B2",
                      "#EDC948",
                      "#9C755F",
                      "#CFCFCF"
                    ]
                  },
                  "legend": null
                },
                "opacity": {
                  "condition": {
                    "param": "hover",
                    "value": 1
                  },
                  "value": 0.75
                }
              }
            },
            {
              "transform": [
                {
                  "filter": "datum.isLatest == true && datum.StateGroup != 'Others'"
                }
              ],
              "mark": {
                "type": "text",
                "align": "left",
                "baseline": "middle",
                "dx": 8,
                "fontSize": 10,
                "fontWeight": "bold"
              },
              "encoding": {
                "text": {"field": "State"},
                "color": {
                  "field": "StateGroup",
                  "type": "nominal",
                  "scale": {
                    "domain": [
                      "Johor",
                      "Perak",
                      "Pahang",
                      "Sabah",
                      "Sarawak",
                      "Selangor"
                    ],
                    "range": [
                      "#4E79A7",
                      "#F28E2B",
                      "#B07AA1",
                      "#76B7B2",
                      "#EDC948",
                      "#9C755F"
                    ]
                  },
                  "legend": null
                }
              }
            },
            {
              "transform": [
                {
                  "filter": "datum.isLatest == true && datum.StateGroup == 'Others'"
                },
                {
                  "joinaggregate": [
                    {
                      "op": "mean",
                      "field": "Value",
                      "as": "MeanOthersValue"
                    }
                  ]
                },
                {
                  "window": [
                    {
                      "op": "row_number",
                      "as": "rowNum"
                    }
                  ]
                },
                {
                  "filter": "datum.rowNum == 1"
                }
              ],
              "mark": {
                "type": "text",
                "align": "left",
                "baseline": "middle",
                "dx": 8,
                "fontSize": 10,
                "fontWeight": "bold",
                "color": "#8F8F8F"
              },
              "encoding": {
                "x": {"field": "Year", "type": "ordinal"},
                "y": {
                  "field": "MeanOthersValue",
                  "type": "quantitative"
                },
                "text": {"value": "Others"}
              }
            }
          ]
        }
      ]
    }
  ],
  "config": {
    "view": {"stroke": null}
  }
}