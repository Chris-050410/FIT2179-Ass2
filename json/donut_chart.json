{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Donut charts showing palm oil production share by country in selected years.",

  "data": {
    "url": "data/CPO-Production.csv"
  },

  "transform": [
    {
      "filter": "datum.Period == 2010 || datum.Period == 2015 || datum.Period == 2020 || datum.Period == 2024"
    },
    {
      "fold": [
        "Indonesia",
        "Malaysia",
        "Thailand",
        "Colombia",
        "Nigeria",
        "Papua New Guinea",
        "Honduras",
        "Ghana"
      ],
      "as": ["Country", "Production"]
    },
    {
      "calculate": "toNumber(datum.Production)",
      "as": "ProductionNum"
    }
  ],

  "facet": {
    "field": "Period",
    "type": "ordinal",
    "title": null
  },

  "columns": 2,

  "spec": {
    "width": 250,
    "height": 250,

    "layer": [
      {
        "mark": {
          "type": "arc",
          "innerRadius": 70,
          "outerRadius": 105,
          "stroke": "white",
          "strokeWidth": 2
        },
        "encoding": {
          "theta": {
            "field": "ProductionNum",
            "type": "quantitative"
          },
          "color": {
            "field": "Country",
            "type": "nominal",
            "scale": {
              "range": [
                "#1f4e79",
                "#4f81bd",
                "#9e7bb5",
                "#f2c14e",
                "#8c6d31",
                "#7f7f7f",
                "#c49a6c",
                "#2f5597"
              ]
            },
            "legend": {
              "title": "Country",
              "orient": "bottom",
              "columns": 2
            }
          },
          "tooltip": [
            {"field": "Period", "type": "ordinal", "title": "Year"},
            {"field": "Country", "type": "nominal"},
            {
              "field": "ProductionNum",
              "type": "quantitative",
              "title": "Production"
            }
          ]
        }
      },
      {
        "transform": [
          {
            "aggregate": [
              {
                "op": "sum",
                "field": "ProductionNum",
                "as": "TotalProduction"
              }
            ],
            "groupby": ["Period"]
          },
          {
            "calculate": "datum.Period + '\\n' + format(datum.TotalProduction, ',')",
            "as": "CenterLabel"
          }
        ],
        "mark": {
          "type": "text",
          "fontSize": 16,
          "fontWeight": "bold",
          "lineBreak": "\n"
        },
        "encoding": {
          "text": {
            "field": "CenterLabel"
          }
        }
      }
    ]
  },

  "resolve": {
    "scale": {
      "color": "shared"
    }
  },

  "config": {
    "view": {
      "stroke": null
    },
    "header": {
      "labelFontSize": 16,
      "labelFontWeight": "bold"
    }
  }
}